      "source": [
        "from alpaca.data.historical import StockHistoricalDataClient\n",
        "from alpaca.data.requests import StockBarsRequest\n",
        "from alpaca.data.timeframe import TimeFrame\n",
        "from google.colab import userdata\n",
        "from datetime import datetime, timezone # Import timezone\n",
        "\n",
        "# 1. Authenticate using Colab Secrets\n",
        "API_KEY = userdata.get('ALPACA_API_KEY')\n",
        "SECRET_KEY = userdata.get('ALPACA_SECRET_KEY')\n",
        "\n",
        "# Initialize the data client\n",
        "data_client = StockHistoricalDataClient(API_KEY, SECRET_KEY)\n",
        "\n",
        "# 2. Fetch Historical Stock Data for all target companies over a wider date range\n",
        "# Update symbol_or_symbols to include all target companies\n",
        "# Update start and end dates for a comprehensive range\n",
        "request_params = StockBarsRequest(\n",
        "    symbol_or_symbols=['TSLA', 'AAPL', 'MSFT'], # Modified to include all CEO companies\n",
        "    timeframe=TimeFrame.Day,\n",
        "    start=datetime(2020, 1, 1, tzinfo=timezone.utc), # Fetch data from 2020-01-01\n",
        "    end=datetime.now(timezone.utc) # Fetch data up to the current date and time\n",
        ")\n",
        "\n",
        "# 3. Retrieve and Convert to a DataFrame\n",
        "bars = data_client.get_stock_bars(request_params)\n",
        "df_stocks = bars.df\n",
        "display(df_stocks.head())"
