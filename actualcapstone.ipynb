        "def send_to_api(dataframe, data_name):\n",
        "    # 1. Map the data_name to your actual Render endpoints\n",
        "    base_url = \"https://moneymaker-1vt4.onrender.com/ingest\"\n",
        "    endpoint_map = {\n",
        "        \"tweets\": f\"{base_url}/tweets\",\n",
        "        \"ceo_tweets_data\": f\"{base_url}/tweets\",\n",
        "        \"stocks\": f\"{base_url}/stocks\",\n",
        "        \"TSLA_stock_data\": f\"{base_url}/stocks\",\n",
        "        \"merged\": f\"{base_url}/merged\",\n",
        "        \"sample_tweet_classification_report\": f\"{base_url}/classified_tweets\",\n",
        "        \"full_tweet_classification_report\": f\"{base_url}/classified_tweets\"\n",
        "    }\n",
        "\n",
        "    api_endpoint = endpoint_map.get(data_name)\n",
        "    if not api_endpoint:\n",
        "        print(f\"❌ Error: data_name '{data_name}' not recognized.\")\n",
        "        return\n",
        "\n",
        "    # --- STEP 1.5: THE FIX FOR THE TIMESTAMP ERROR ---\n",
        "    # We create a copy so we don't change your original Colab data\n",
        "    df_ready = dataframe.copy()\n",
        "\n",
        "    # This finds any 'date' or 'timestamp' columns and turns them into strings\n",
        "    for col in df_ready.columns:\n",
        "        if pd.api.types.is_datetime64_any_dtype(df_ready[col]):\n",
        "            df_ready[col] = df_ready[col].dt.strftime('%Y-%m-%d')\n",
        "    # --------------------------------------------------\n",
        "\n",
        "    # 2. Convert DataFrame to a list of dictionaries\n",
        "    json_payload = df_ready.to_dict(orient='records')\n",
        "\n",
        "    print(f\"🚀 Sending {len(json_payload)} rows to {api_endpoint}...\")\n",
        "\n",
        "    # 3. Actual API Call\n",
        "    try:\n",
        "        # Use 'json=' to handle the serialization automatically\n",
        "        response = requests.post(api_endpoint, json=json_payload)\n",
        "\n",
        "        if response.status_code == 200:\n",
        "            print(f\"✅ Success! {data_name} data saved to Neon.\")\n",
        "        else:\n",
        "            print(f\"❌ API Error {response.status_code}: {response.text}\")\n",
        "\n",
        "    except requests.exceptions.RequestException as e:\n",
        "        print(f\"⚠️ Connection failed: {e}\")"
